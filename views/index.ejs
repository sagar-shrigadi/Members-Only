<%- include('./partials/header.ejs') %>
<main>
    <section>
        <% if (locals.currentUser) { %>
            <article>
                <div>
                    <% if (currentUser.admin) { %>
                        <h1>Welcome, <%= currentUser.firstname %> (Admin)</h1>
                    <% } else { %>
                        <h1>Welcome, <%= currentUser.firstname %></h1>
                    <% } %>
                    <a href="/user/<%= currentUser.id %>">Profile</a><br>
                    <a href="/logout">Logout</a>
                </div>
                <p>Membership Status: <%= currentUser.membership_status %></p>
                <% if(currentUser.membership_status === 'user') { %>
                    <p>Become a member to see the author and posted date of messages created by other users...</p>
                    <a href="/upgrade-status">Become a Member</a><br />
                <% } %>
            </article>
        <% } %>
        <% if (!locals.currentUser) { %>
            <a href="/register">Register</a><span style="margin-left: .25em;">To freely chat with like minded users!</span>
        <% } %>
        <section>
            <div>
                <h2>Messages</h2>
                <a href="/message/new">Create New Message</a><br/>
            </div>
            <% if (locals.allMsg) { %>
                <% allMsg.map(msg => { %>
                    <article>
                        <div>
                            <h3><%= msg.title %></h3>
                            <% if(currentUser && (currentUser.membership_status !== 'user' || msg.user_id === currentUser.id)) { %>
                                <p><%= msg.created_at.toDateString() %></p>
                            <% } %>
                        </div>
                        <p><%= msg.message_content %></p>
                        <% if (currentUser && (currentUser.membership_status !== 'user' || msg.user_id === currentUser.id)) { %>
                            <p>Author: <%= msg.firstname %></p>
                        <% } %>
                        <%# allow admins to be able to delete anyone's message%>
                        <% if (currentUser && currentUser.admin) { %>
                            <form action="/message/<%= msg.mid %>/delete" method="post">
                                <button type="submit" onclick="confirm(`Are you sure you want to delete this message\nby user: <%= msg.firstname %>\nposted on: <%= msg.created_at.toDateString() %>`)">Delete</button>
                            </form>
                        <% } %>
                    </article>
                <% }) %>
            <% } %>
        </section>
    </section>

</main>
<%- include('./partials/footer.ejs') %>