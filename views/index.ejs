<%- include('./partials/header.ejs') %>
<main>
    <section>
        <% if (locals.currentUser) { %>
            <div>
                <div>
                    <h1>Welcome, <%= currentUser.firstname %></h1>
                    <a href="/user/<%= currentUser.id %>">Profile</a><br>
                    <a href="/logout">Logout</a>
                </div>
                <p>Membership Status: <%= currentUser.membership_status %></p>
                <% if(currentUser.membership_status === 'user') { %>
                    <p>Become a member to see the author and posted date of messages created by other users...</p>
                    <a href="/upgrade-status">Become a Member</a><br />
                <% } %>
            </div>
            <div>
                <h2>Messages</h2>
                <a href="/message/new">Create New Message</a><br/>
            </div>
            <% if (locals.allMsg) { %>
                <% allMsg.map(msg => { %>
                    <article>
                        <div>
                            <h3><%= msg.title %></h3>
                            <% if(currentUser.membership_status !== 'user' || msg.user_id === currentUser.id) { %>
                                <p><%= msg.created_at.toDateString() %></p>
                            <% } %>
                        </div>
                        <p><%= msg.message_content %></p>
                        <% if (currentUser.membership_status !== 'user' || msg.user_id === currentUser.id) { %>
                            <p>Author: <%= msg.firstname %></p>
                        <% } %>
                    </article>
                <% }) %>
            <% } %>
        <% } else { %>
            <h1>Please Register to Continue!</h1>
            <%- include('./partials/error.ejs') %>
            <article>
                <form action="register" method="post">
                    <div class="name">
                        <div>
                            <label for="firstname">First Name: </label>
                            <input type="text" name="firstname" id="firstname" required>
                        </div>
                        <div>
                            <label for="lastname">Last Name: </label>
                            <input type="text" name="lastname" id="lastname" required>
                        </div>
                    </div>
                    <div>
                        <label for="username">Username: </label>
                        <input type="email" name="username" id="username" placeholder="test@example.com" required>
                    </div>
                    <div>
                        <label for="password">Password: </label>
                        <input type="password" name="password" id="password" required>
                    </div>
                    <div>
                        <label for="passwordConfirmation">Confirm Password: </label>
                        <input type="password" name="passwordConfirmation" id="passwordConfirmation" required>
                    </div>
                    <button type="submit">Register</button>
                </form>
                <p>Already have an account?</p>
                <a href="/login">Login</a>
            </article>
        <% } %>
    </section>

</main>
<%- include('./partials/footer.ejs') %>